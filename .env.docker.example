# Flask application
FLASK_APP=run.py
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
PORT=5000
DEBUG=False

# Security
SECRET_KEY=change-this-to-a-random-long-secret-key

# Database
POSTGRES_DB=lbb_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/lbb_db

# App settings
LOG_LEVEL=INFO
PAGINATION_PER_PAGE=20
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
RECRUITMENT_BASE_URL=https://recruitment.supersmart.click
RECRUITMENT_HOST=recruitment.supersmart.click
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
SESSION_COOKIE_DOMAIN=.supersmart.click

# Optional startup tuning
DB_WAIT_TIMEOUT=60
GUNICORN_WORKERS=3
