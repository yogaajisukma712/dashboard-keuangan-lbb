# ============================================================
# LBB Super Smart – Dashboard Keuangan
# .env.example – Salin file ini menjadi .env dan sesuaikan nilainya
# Domain: billing.supersmart.click  |  Port: 6001
# Tutor portal: tutor.supersmart.click | Port: 6003
# ============================================================

# ── Flask ────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_APP=run.py
DEBUG=False
# WAJIB diganti dengan string acak yang panjang dan unik!
SECRET_KEY=ganti-dengan-secret-key-yang-kuat-dan-panjang

# ── App ──────────────────────────────────────────────────────
APP_PORT=6001
APP_BASE_URL=https://billing.supersmart.click
TUTOR_PORTAL_PORT=6003
TUTOR_PORTAL_BASE_URL=https://tutor.supersmart.click
TUTOR_PORTAL_HOST=tutor.supersmart.click
TUTOR_PORTAL_MIN_DATE=2026-04-01

# ── Database PostgreSQL ──────────────────────────────────────
POSTGRES_DB=lbb_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ganti-password-database-anda
# Port host untuk PostgreSQL (hindari konflik dengan port 5432 yang sudah ada)
POSTGRES_PORT=5433

# ── Identitas Lembaga ────────────────────────────────────────
INSTITUTION_NAME=LBB Super Smart
INSTITUTION_TAGLINE=BEING SMART FOR FUTURE
INSTITUTION_PHONE=0895-6359-07419
INSTITUTION_EMAIL=lbbsupersmart@gmail.com
INSTITUTION_ADDRESS=Jl. Menur Pumpungan No 63, Sukolilo
INSTITUTION_CITY=Surabaya
INSTITUTION_CEO_NAME=Yoga Aji Sukma, S.Mat., M.Stat.
INSTITUTION_CEO_TITLE=CEO

# Format: "NamaBank (PemilikRekening) - NomorRekening" dipisah tanda |
INSTITUTION_BANK_ACCOUNTS=BCA (Yoga Aji Sukma) - 5200540672|BNI (Yoga Aji Sukma) - 0809530111|BRI (Yoga Aji Sukma) - 185901010065501|Permata (Yoga Aji Sukma) - 4129843662|BSI (Yoga Aji Sukma) - 7311274753|Bank Jago (Yoga Aji Sukma) - 105576621785|SeaBank (Yoga Aji Sukma) - 901687553404

# ── Upload & Logging ─────────────────────────────────────────
UPLOAD_FOLDER=uploads
# 16 MB dalam bytes
MAX_CONTENT_LENGTH=16777216
LOG_LEVEL=INFO
PAGINATION_PER_PAGE=20

# ── Email verifikasi Dashboard Tutor ───────────────────────
# Bisa diarahkan ke layanan mail open-source/self-hosted seperti Postal,
# Mailu, Docker Mailserver, atau Mailpit untuk staging.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=lbbsupersmart@gmail.com
MAIL_PASSWORD=
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_DEFAULT_SENDER=lbbsupersmart@gmail.com

# ── WhatsApp Bot ─────────────────────────────────────────────
WHATSAPP_BOT_TOKEN=ganti-token-internal-whatsapp-bot
WHATSAPP_EXCLUDED_GROUP_NAMES=VPS / RDP MURAH III
WWEBJS_CLIENT_ID=billing-supersmart
WHATSAPP_SYNC_MESSAGE_LIMIT=500
WHATSAPP_AUTO_START=true
WHATSAPP_AUTO_SYNC_ENABLED=true
WHATSAPP_AUTO_SYNC_FULL_SYNC=true
WHATSAPP_AUTO_SYNC_INTERVAL_MS=21600000
WHATSAPP_WATCHDOG_INTERVAL_MS=60000
WHATSAPP_RECONNECT_DELAY_MS=15000
WHATSAPP_READY_TIMEOUT_MS=120000
PUPPETEER_PROTOCOL_TIMEOUT_MS=180000
