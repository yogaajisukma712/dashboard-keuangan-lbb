<edit_description>
Create admin user setup script for initial database population
</edit_description>

```
#!/usr/bin/env python
"""
Create initial admin user for Dashboard Keuangan LBB Super Smart
Run this after first deployment to Railway
"""

import os
import sys
from app import create_app, db
from app.models import User

def create_admin():
    """Create admin user"""
    os.environ['FLASK_ENV'] = 'production'
    app = create_app('production')

    with app.app_context():
        try:
            # Check if admin already exists
            admin = User.query.filter_by(username='admin').first()
            if admin:
                print("❌ Admin user already exists!")
                return False

            # Create admin user
            admin = User(
                username='admin',
                email='admin@lbb-super-smart.com',
                full_name='Administrator LBB Super Smart',
                role='admin',
                is_active=True
            )
            admin.set_password('admin123456')  # CHANGE THIS IMMEDIATELY!

            db.session.add(admin)
            db.session.commit()

            print("✅ Admin user created successfully!")
            print("")
            print("=" * 50)
            print("LOGIN CREDENTIALS")
            print("=" * 50)
            print(f"Username: admin")
            print(f"Password: admin123456")
            print("")
            print("⚠️  IMPORTANT: Change this password immediately!")
            print("=" * 50)

            return True

        except Exception as e:
            print(f"❌ Error creating admin user: {str(e)}")
            db.session.rollback()
            return False

def create_sample_data():
    """Create sample master data"""
    os.environ['FLASK_ENV'] = 'production'
    app = create_app('production')

    with app.app_context():
        try:
            from app.models import Curriculum, Level, Subject

            # Check if data already exists
            if Curriculum.query.first():
                print("Sample data already exists, skipping...")
                return True

            # Create Curriculums
            curriculums = [
                Curriculum(name="Nasional", description="Kurikulum Nasional Indonesia"),
                Curriculum(name="Internasional", description="Kurikulum Internasional"),
                Curriculum(name="Cambridge", description="Cambridge Curriculum"),
            ]

            # Create Levels
            levels = [
                Level(name="TK", description="Taman Kanak-Kanak"),
                Level(name="SD", description="Sekolah Dasar"),
                Level(name="SMP", description="Sekolah Menengah Pertama"),
                Level(name="SMA", description="Sekolah Menengah Atas"),
            ]

            # Create Subjects
            subjects = [
                Subject(name="Matematika", description="Mata Pelajaran Matematika"),
                Subject(name="Bahasa Indonesia", description="Mata Pelajaran Bahasa Indonesia"),
                Subject(name="Bahasa Inggris", description="Mata Pelajaran Bahasa Inggris"),
                Subject(name="IPA", description="Ilmu Pengetahuan Alam"),
                Subject(name="IPS", description="Ilmu Pengetahuan Sosial"),
            ]

            # Add all to session
            db.session.add_all(curriculums)
            db.session.add_all(levels)
            db.session.add_all(subjects)
            db.session.commit()

            print("✅ Sample master data created successfully!")
            print(f"   - {len(curriculums)} Curriculums")
            print(f"   - {len(levels)} Levels")
            print(f"   - {len(subjects)} Subjects")

            return True

        except Exception as e:
            print(f"❌ Error creating sample data: {str(e)}")
            db.session.rollback()
            return False

if __name__ == '__main__':
    print("")
    print("=" * 50)
    print("Dashboard Keuangan LBB Super Smart")
    print("Initial Setup")
    print("=" * 50)
    print("")

    # Create admin
    print("[1/2] Creating admin user...")
    admin_created = create_admin()

    if admin_created:
        print("")
        print("[2/2] Creating sample master data...")
        data_created = create_sample_data()

        if data_created:
            print("")
            print("=" * 50)
            print("✅ SETUP COMPLETE")
            print("=" * 50)
            print("")
            print("Your application is ready!")
            print("Visit: https://your-app-name.up.railway.app")
            print("")
            sys.exit(0)

    print("")
    print("❌ Setup failed. Please check the errors above.")
    sys.exit(1)
```

