```
"""
Health check utilities for Railway deployment monitoring
"""

from app import create_app, db
from app.models import User
import os

def check_database_connection():
    """Check if database is accessible"""
    app = create_app(os.getenv('FLASK_ENV', 'production'))

    with app.app_context():
        try:
            # Try simple query
            User.query.first()
            return True, "Database connection OK"
        except Exception as e:
            return False, f"Database error: {str(e)}"

def check_app_startup():
    """Check if app starts without errors"""
    try:
        app = create_app(os.getenv('FLASK_ENV', 'production'))
        return True, "App startup OK"
    except Exception as e:
        return False, f"App startup error: {str(e)}"

if __name__ == '__main__':
    print("Railway Health Checks")
    print("=" * 50)

    # Check app startup
    print("\n[1] App Startup Check...")
    startup_ok, startup_msg = check_app_startup()
    print(f"   {'✅' if startup_ok else '❌'} {startup_msg}")

    # Check database
    print("\n[2] Database Connection Check...")
    db_ok, db_msg = check_database_connection()
    print(f"   {'✅' if db_ok else '❌'} {db_msg}")

    print("\n" + "=" * 50)
    if startup_ok and db_ok:
        print("✅ All checks passed!")
    else:
        print("❌ Some checks failed!")
```

