{
  "name": "dashboard-keuangan-lbb",
  "description": "Dashboard Keuangan LBB Super Smart",
  "services": [
    {
      "name": "database",
      "type": "postgres",
      "plan": "starter"
    },
    {
      "name": "web",
      "type": "web",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "gunicorn -w 4 -b 0.0.0.0:$PORT run:app",
      "envVariables": {
        "FLASK_ENV": "production",
        "FLASK_APP": "run.py",
        "PYTHONUNBUFFERED": "1"
      },
      "domains": [
        {
          "name": "your-app-name"
        }
      ]
    }
  ]
}
